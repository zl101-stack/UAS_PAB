<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- ── Thumbnail area ── -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="80dp"
            android:layout_marginEnd="12dp">

            <!-- Thumbnail image (background emoji placeholder) -->
            <TextView
                android:id="@+id/tvThumbnailEmoji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🎬"
                android:textSize="28sp"
                android:background="#E0E7FF" />

            <!-- Play button overlay -->
            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:background="#CC1A56DB">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="▶"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </FrameLayout>

            <!-- Durasi badge di kanan bawah -->
            <TextView
                android:id="@+id/tvDurasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:text="8:24"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#CC000000"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp" />
        </FrameLayout>

        <!-- ── Info area ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Badge Kategori -->
            <TextView
                android:id="@+id/tvKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Investasi"
                android:textColor="#1A56DB"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="#EEF2FF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="6dp" />

            <!-- Judul video -->
            <TextView
                android:id="@+id/tvJudul"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cara Investasi Saham untuk Pemula"
                android:textColor="#0F172A"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="8dp" />

            <!-- Baris bawah: channel + views -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvChannel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📺 Dana Bijak"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- YouTube icon badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YouTube"
                    android:textColor="#FF0000"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="#FFEEEE"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
