<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header & Tombol Kembali -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#0F172A"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kontrol Budget"
            android:textColor="#0F172A"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- Navigasi Bulan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/btnPrevMonth"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#1A56DB"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"/>

        <TextView
            android:id="@+id/tvMonthYear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bulan Tahun"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginHorizontal="24dp"/>

        <ImageView
            android:id="@+id/btnNextMonth"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_next"
            app:tint="#1A56DB"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- Card 1: Ringkasan Budget -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sisa Saldo Budget Saat Ini:"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <!-- Sisa Uang Budget -->
            <TextView
                android:id="@+id/tvSisaBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="#10B981"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="16dp"/>

            <ProgressBar
                android:id="@+id/progressBarBudget"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="#1A56DB"
                android:max="100"
                android:progress="0"
                android:layout_marginBottom="12dp"/>

            <!-- Teks Terpakai X / Y -->
            <TextView
                android:id="@+id/tvTerpakai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Terpakai Rp 0 / Rp 0"
                android:textColor="#334155"
                android:textSize="15sp"
                android:fontFamily="sans-serif-bold"
                android:gravity="center"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Card 2: Aksi (Atur & Kurangi) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Aksi 1: Atur / Edit Budget -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Buat / Edit Target Budget"
                    android:textColor="#0F172A"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etBudgetLimit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Nominal Target (Cth: 1000000)"
                    android:inputType="number"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSaveBudget"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Simpan Budget"
                    android:textAllCaps="false"
                    android:backgroundTint="#1A56DB"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="15sp"
                    app:cornerRadius="10dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginVertical="20dp"/>

                <!-- Aksi 2: Kurangi Dana -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Kurangi Dana (Pemakaian Baru)"
                    android:textColor="#0F172A"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etUseBudget"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Nominal Pakai (Cth: 50000)"
                    android:inputType="number"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnUseBudget"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Kurangi Dana"
                    android:textAllCaps="false"
                    android:backgroundTint="#EF4444"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="15sp"
                    app:cornerRadius="10dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginVertical="20dp"/>

                <!-- Aksi 3: Reset Budget -->
                <Button
                    android:id="@+id/btnResetBudget"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Reset Budget Bulan Ini"
                    android:textAllCaps="false"
                    android:backgroundTint="#94A3B8"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="15sp"
                    app:cornerRadius="10dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>
</LinearLayout>