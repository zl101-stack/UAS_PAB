<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header & Tombol Kembali -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#0F172A"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kontrol Budget"
            android:textColor="#0F172A"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- Card 1: Input Target Budget -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Atur Anggaran Bulanan"
                android:textColor="#334155"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etBudgetLimit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_edittext"
                android:hint="Contoh: 5000000"
                android:inputType="number"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnSaveBudget"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Simpan Anggaran"
                android:textAllCaps="false"
                android:backgroundTint="#1A56DB"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:textSize="15sp"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Card 2: Analisa Pengeluaran -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ringkasan Bulan Ini"
                android:textColor="#334155"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="20dp"/>

            <!-- Sisa Anggaran -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sisa Anggaran Anda:"
                android:textColor="#64748B"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvSisaBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="#10B981"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="16dp"/>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBarBudget"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="#1A56DB"
                android:max="100"
                android:progress="0"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvStatusPersentase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Terpakai 0%"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_gravity="end"
                android:layout_marginBottom="20dp"/>

            <!-- Detail Perbandingan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target"
                        android:textColor="#64748B"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTargetBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pengeluaran"
                        android:textColor="#64748B"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTotalPengeluaran"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="#EF4444"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>