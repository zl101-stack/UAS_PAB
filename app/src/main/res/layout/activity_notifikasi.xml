<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F9">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A56DB"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <!-- Baris atas: back + judul + tandai semua -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Kembali"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notifikasi"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/tvTandaiSemua"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tandai Dibaca"
                android:textColor="#BFDBFE"
                android:textSize="12sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- Badge jumlah belum dibaca -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginStart="44dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_merah"/>

            <TextView
                android:id="@+id/tvJumlahBelumDibaca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 notifikasi belum dibaca"
                android:textColor="#BFDBFE"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- FILTER CHIP GROUP -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipSemua"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Semua"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_chip_aktif"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chipPeringatan"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="⚠ Peringatan"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:background="@drawable/bg_chip_nonaktif"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chipInfo"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="ℹ Info"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:background="@drawable/bg_chip_nonaktif"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chipSukses"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="✓ Sukses"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:background="@drawable/bg_chip_nonaktif"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chipTips"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="💡 Tips"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:background="@drawable/bg_chip_nonaktif"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- LIST NOTIFIKASI -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:paddingTop="12dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/llNotifikasiContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp"/>
    </ScrollView>

</LinearLayout>
